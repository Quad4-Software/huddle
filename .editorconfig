root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{go,ts,svelte,css,js,yml,yaml}]
indent_style = tab

[*.go]
indent_style = tab

[*.{ts,svelte,css,js,json,html}]
indent_style = space
indent_size = 2

[Taskfile.yml]
indent_style = space
indent_size = 2
