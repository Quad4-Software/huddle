# Example reverse-proxy settings for HTTPS/WSS in front of Huddle.
# Terminate TLS at the proxy and forward plain HTTP to huddle:8080.
# Set HUDDLE_TRUST_PROXY=true on the Huddle container.

# nginx
location / {
    proxy_pass http://huddle:8080;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
}

